pipeline {
agent any

tools {
    maven 'Maven3'
}

stages {

    stage('Checkout') {
        steps {
            checkout scm
        }
    }

    stage('Build') {
        steps {
            bat 'mvn clean package -DskipTests'
        }
    }

    stage('Publish to Exchange') {
        steps {
            withCredentials([usernamePassword(
                credentialsId: 'anypoint-creds',
                usernameVariable: 'ANYPOINT_USER',
                passwordVariable: 'ANYPOINT_PASS'
            )]) {
                bat '''
                    mvn deploy ^
                        -DskipTests ^
                        -Duser=%ANYPOINT_USER% ^
                        -Dpass=%ANYPOINT_PASS%
                '''
            }
        }
    }

    stage('Deploy to CloudHub 2.0') {
        steps {
            withCredentials([usernamePassword(
                credentialsId: 'anypoint-creds',
                usernameVariable: 'ANYPOINT_USER',
                passwordVariable: 'ANYPOINT_PASS'
            )]) {
                bat '''
                    mvn mule:deploy ^
                        -DmuleDeploy ^
                        -Duser=%ANYPOINT_USER% ^
                        -Dpass=%ANYPOINT_PASS% ^
                        -DapplicationName=test-p-d-d-jenkins
                '''
            }
        }
    }
}

post {
    success {
        echo 'BUILD SUCCESS — deployed to CloudHub 2.0'
    }
    failure {
        echo 'BUILD FAILED — check logs'
    }
}

}
