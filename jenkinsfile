pipeline {
agent any

tools {
    maven 'Maven3'
}

stages {

    stage('Checkout') {
        steps {
            checkout scm
        }
    }

    stage('Prepare settings.xml') {
        steps {
            withCredentials([usernamePassword(
                credentialsId: 'anypoint-creds',
                usernameVariable: 'ANYPOINT_USER',
                passwordVariable: 'ANYPOINT_PASS'
            )]) {
                writeFile file: 'settings.xml', text: """
```

<settings>
  <servers>
    <server>
      <id>Repository</id>
      <username>${ANYPOINT_USER}</username>
      <password>${ANYPOINT_PASS}</password>
    </server>
  </servers>
</settings>
"""
                }
            }
        }

```
    stage('Build & Publish to Exchange') {
        steps {
            withCredentials([usernamePassword(
                credentialsId: 'anypoint-creds',
                usernameVariable: 'ANYPOINT_USER',
                passwordVariable: 'ANYPOINT_PASS'
            )]) {
                bat 'mvn clean deploy -s settings.xml -DskipTests -Duser=%ANYPOINT_USER% -Dpass=%ANYPOINT_PASS%'
            }
        }
    }

    stage('Deploy to CloudHub 2.0') {
        steps {
            withCredentials([usernamePassword(
                credentialsId: 'anypoint-creds',
                usernameVariable: 'ANYPOINT_USER',
                passwordVariable: 'ANYPOINT_PASS'
            )]) {
                bat '''
                    mvn mule:deploy ^
                        -DmuleDeploy ^
                        -Duser=%ANYPOINT_USER% ^
                        -Dpass=%ANYPOINT_PASS% ^
                        -DapplicationName=test-p-d-d-jenkins
                '''
            }
        }
    }
}

post {
    success {
        echo 'BUILD SUCCESS — Exchange + CloudHub deployment completed'
    }
    failure {
        echo 'BUILD FAILED — check logs'
    }
}

}
